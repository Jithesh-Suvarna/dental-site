rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Helper primitives
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    // Validation helper for appointments
    function isValidAppointment(data) {
      return data.keys().hasAll(['name', 'phone', 'email', 'service', 'date', 'time', 'createdAt'])
        && data.keys().size() >= 7
        && data.keys().size() <= 8
        && data.name is string && data.name.size() >= 2 && data.name.size() <= 100
        && data.phone is string && data.phone.size() >= 8 && data.phone.size() <= 20
        && data.email is string && data.email.size() >= 5 && data.email.size() <= 100
        && data.service is string && data.service.size() >= 2 && data.service.size() <= 100
        && data.date is string && data.date.size() == 10
        && data.time is string && data.time.size() >= 3 && data.time.size() <= 50
        && (!data.keys().hasAll(['message']) || (data.message is string && data.message.size() <= 1000))
        && data.createdAt is string && data.createdAt.size() <= 50;
    }
    
    match /appointments/{appointmentId} {
      allow create: if isValidId(appointmentId) && isValidAppointment(incoming());
      allow read, update, delete: if false;
    }
  }
}
